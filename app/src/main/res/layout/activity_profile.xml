<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F4F0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- SCROLLABLE PROFILE CONTENT -->
    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- PROFILE HERO HEADER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/hero_bg">

                <ImageView
                    android:src="@drawable/fast_food_icon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="end|bottom"
                    android:layout_margin="16dp"
                    android:alpha="0.25"
                    android:scaleType="fitCenter"/>

                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/avatar_bg">
                        <TextView
                            android:text="👤"
                            android:textSize="44sp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/profileTitle"
                        android:text="John Doe"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Food lover 🍔"
                        android:textSize="13sp"
                        android:textColor="#FFE4CC"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>

            <!-- STATS ROW -->
            <LinearLayout
                android:id="@+id/profileHeader"
                android:orientation="horizontal"
                android:background="@drawable/card_bg"
                android:elevation="8dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:padding="16dp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="12" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#FF6B35" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Orders" android:textSize="11sp" android:textColor="#9CA3AF"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#F3F4F6" android:layout_gravity="center_vertical"/>

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:padding="16dp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="5" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#FF6B35" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Favourites" android:textSize="11sp" android:textColor="#9CA3AF"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#F3F4F6" android:layout_gravity="center_vertical"/>

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:padding="16dp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="3" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#FF6B35" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Reviews" android:textSize="11sp" android:textColor="#9CA3AF"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- INFO CARD -->
            <LinearLayout
                android:id="@+id/infoCard"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:elevation="6dp"
                android:padding="20dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView android:text="Account Details" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="#1E2A38"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <!-- EMAIL -->
                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="✉️" android:textSize="20sp" android:layout_marginEnd="14dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                        <TextView android:text="Email" android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="john@email.com" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="#1E2A38" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                <!-- PHONE -->
                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="📞" android:textSize="20sp" android:layout_marginEnd="14dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                        <TextView android:text="Phone" android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="+1 234 567 890" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="#1E2A38" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                <!-- ADDRESS -->
                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="📍" android:textSize="20sp" android:layout_marginEnd="14dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                        <TextView android:text="Address" android:textSize="11sp" android:textColor="#9CA3AF"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="123 Main Street, City" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="#1E2A38" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- LOGOUT BUTTON -->
            <Button
                android:text="Logout"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="@drawable/btn_danger"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="28dp"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="56dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/navHome"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🏠" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Home" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- MENU -->
        <LinearLayout
            android:id="@+id/navRestaurant"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🍽️" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Menu" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CART -->
        <LinearLayout
            android:id="@+id/navCart"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🛒" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Cart" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- PROFILE (active) -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="@drawable/nav_indicator"
                android:layout_marginBottom="4dp"/>
            <TextView android:text="👤" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Profile" android:textSize="10sp"
                android:textColor="#FF6B35" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>