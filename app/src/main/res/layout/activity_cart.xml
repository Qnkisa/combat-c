<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F4F0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════ -->
    <!--  TOP BAR                                   -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:orientation="horizontal"
        android:background="@drawable/hero_bg"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/cartTitle"
                android:text="Your Cart"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Review your order"
                android:textSize="13sp"
                android:textColor="#FFE4CC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Cart icon badge area -->
        <TextView
            android:text="🛒"
            android:textSize="26sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  CART ITEMS LIST                           -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/cartItems"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/summaryCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0">

        <!-- ────── Cart Item: Pizza ────── -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Food Thumbnail -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#FFF9F0">

                <ImageView
                    android:src="@drawable/pizza"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"/>
            </FrameLayout>

            <!-- Details -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="14dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Pepperoni Pizza"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E2A38"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Qty: 1"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Qty stepper -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="−"
                        android:textSize="18sp"
                        android:textColor="#FF6B35"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="1"
                        android:textSize="14sp"
                        android:textColor="#1E2A38"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="#FF6B35"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Price -->
            <TextView
                android:text="$12.99"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FF6B35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- ────── Cart Item: Burger ────── -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Food Thumbnail -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#FFF5F0">

                <ImageView
                    android:src="@drawable/burger"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"/>
            </FrameLayout>

            <!-- Details -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="14dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Beef Burger"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E2A38"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Qty: 1"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Qty stepper -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="−"
                        android:textSize="18sp"
                        android:textColor="#FF6B35"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="1"
                        android:textSize="14sp"
                        android:textColor="#1E2A38"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="#FF6B35"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Price -->
            <TextView
                android:text="$9.99"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FF6B35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  ORDER SUMMARY CARD                        -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/summaryCard"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:elevation="10dp"
        android:padding="20dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/btnCheckout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:text="Order Summary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1E2A38"
            android:layout_marginBottom="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Row: Subtotal -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">
            <TextView
                android:text="Subtotal"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="$22.98"
                android:textSize="14sp"
                android:textColor="#1E2A38"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Row: Delivery -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">
            <TextView
                android:text="Delivery fee"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="$2.00"
                android:textSize="14sp"
                android:textColor="#1E2A38"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginBottom="10dp"/>

        <!-- Row: Total -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:text="Total"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E2A38"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="$24.98"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  CHECKOUT BUTTON                           -->
    <!-- ══════════════════════════════════════════ -->
    <Button
        android:id="@+id/btnCheckout"
        android:text="Proceed to Checkout  →"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/btn_primary"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:layout_width="0dp"
        android:layout_height="56dp"/>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/navHome"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🏠" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Home" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- MENU -->
        <LinearLayout
            android:id="@+id/navRestaurant"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🍽️" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Menu" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CART (active) -->
        <LinearLayout
            android:id="@+id/navCart"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="@drawable/nav_indicator"
                android:layout_marginBottom="4dp"/>
            <TextView android:text="🛒" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Cart" android:textSize="10sp"
                android:textColor="#FF6B35" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="👤" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Profile" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>