<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F4F0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════ -->
    <!--  FOOD HERO IMAGE (full-width, tall)        -->
    <!-- ══════════════════════════════════════════ -->
    <ImageView
        android:id="@+id/foodImage"
        android:src="@drawable/burger"
        android:scaleType="centerCrop"
        android:layout_width="0dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dark gradient scrim over image bottom -->
    <View
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#CC000000"
        android:alpha="0.35"
        app:layout_constraintBottom_toBottomOf="@id/foodImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Back arrow (top-left on image) -->
    <TextView
        android:id="@+id/btnBack"
        android:text="←"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:background="#55000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:layout_margin="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ══════════════════════════════════════════ -->
    <!--  CONTENT CARD (slides up over image)       -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentCard"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:elevation="10dp"
        android:padding="24dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/foodImage"
        app:layout_constraintBottom_toTopOf="@id/btnAddToCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="-36dp"
        android:layout_marginBottom="8dp">

        <!-- NAME -->
        <TextView
            android:id="@+id/foodName"
            android:text="Beef Burger"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E2A38"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- RATING ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text="⭐ 4.8"
                android:textSize="14sp"
                android:textColor="#FF6B35"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="  •  20-30 min delivery"
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- TAGS ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text=" 🔥 Popular "
                android:textSize="11sp"
                android:textColor="#FF6B35"
                android:textStyle="bold"
                android:background="#FFF5F0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text=" 🌿 Fresh "
                android:textSize="11sp"
                android:textColor="#22C55E"
                android:textStyle="bold"
                android:background="#F0FFF4"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- DESCRIPTION -->
        <TextView
            android:id="@+id/foodDesc"
            android:text="A juicy grilled beef patty topped with crisp lettuce, ripe tomato, melted cheese and our signature smoky sauce — all in a toasted brioche bun."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:lineSpacingExtra="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- PRICE -->
        <TextView
            android:id="@+id/foodPrice"
            android:text="$9.99"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF6B35"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ADD TO CART BUTTON -->
    <Button
        android:id="@+id/btnAddToCart"
        android:text="🛒  Add to Cart"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:layout_width="0dp"
        android:layout_height="56dp"/>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/navHome"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🏠" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Home" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- MENU (active) -->
        <LinearLayout
            android:id="@+id/navRestaurant"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="@drawable/nav_indicator"
                android:layout_marginBottom="4dp"/>
            <TextView android:text="🍽️" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Menu" android:textSize="10sp"
                android:textColor="#FF6B35" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CART -->
        <LinearLayout
            android:id="@+id/navCart"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🛒" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Cart" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="👤" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Profile" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>