<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F9FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FOOD IMAGE -->
    <ImageView
        android:id="@+id/foodImage"
        android:src="@drawable/ic_launcher_background"
        android:scaleType="centerCrop"
        android:layout_width="0dp"
        android:layout_height="260dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTENT CARD -->
    <LinearLayout
        android:id="@+id/contentCard"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:elevation="6dp"
        android:padding="20dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/foodImage"
        app:layout_constraintBottom_toTopOf="@id/btnAddToCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-30dp">

        <!-- NAME -->
        <TextView
            android:id="@+id/foodName"
            android:text="Pepperoni Pizza"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E2A38"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- RATING -->
        <TextView
            android:text="⭐ 4.8 • 20-30 min delivery"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- DESCRIPTION -->
        <TextView
            android:id="@+id/foodDesc"
            android:text="A delicious Italian classic with crispy crust, rich tomato sauce, mozzarella cheese and spicy pepperoni slices."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- PRICE -->
        <TextView
            android:id="@+id/foodPrice"
            android:text="$12.99"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#D4AF37"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ADD TO CART BUTTON -->
    <Button
        android:id="@+id/btnAddToCart"
        android:text="Add to Cart"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#D4AF37"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"
        android:layout_width="0dp"
        android:layout_height="56dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>