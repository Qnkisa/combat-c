<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F9FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App Title -->
    <TextView
        android:id="@+id/title"
        android:text="FoodDash"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E2A38"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:text="What are you craving today?"
        android:textSize="16sp"
        android:textColor="#6B7280"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Grid -->
    <GridLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Burger Card -->
        <LinearLayout
            android:id="@+id/cardBurger"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/card_bg"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_crop"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Burgers"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Juicy &amp; grilled"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Pizza Card -->
        <LinearLayout
            android:id="@+id/cardPizza"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/card_bg"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Pizza"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Hot &amp; cheesy"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Drinks -->
        <LinearLayout
            android:id="@+id/cardDrinks"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/card_bg"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_slideshow"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Drinks"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Cold &amp; refreshing"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Desserts -->
        <LinearLayout
            android:id="@+id/cardDesserts"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/card_bg"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_compass"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Desserts"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Sweet treats"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>