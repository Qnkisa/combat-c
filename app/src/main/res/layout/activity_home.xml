<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8F4F0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                        -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HERO BANNER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/hero_bg">

                <ImageView
                    android:src="@drawable/fast_food_icon"
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_gravity="end|bottom"
                    android:layout_margin="12dp"
                    android:alpha="0.9"
                    android:scaleType="fitCenter"/>

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Good Afternoon! 👋"
                        android:textSize="14sp"
                        android:textColor="#FFE4CC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/title"
                        android:text="FoodDash"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/subtitle"
                        android:text="What are you craving today?"
                        android:textSize="14sp"
                        android:textColor="#FFE4CC"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="🔥  Hot deals today!"
                        android:textSize="12sp"
                        android:textColor="#FF6B35"
                        android:textStyle="bold"
                        android:background="#FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginTop="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>

            <!-- SECTION LABEL -->
            <TextView
                android:text="Browse Categories"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1E2A38"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Pick your favourite meal"
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- CATEGORY GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingHorizontal="12dp"
                android:paddingBottom="24dp">

                <!-- Burger Card -->
                <LinearLayout
                    android:id="@+id/cardBurger"
                    android:orientation="vertical"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:elevation="6dp"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="#FFF5F0">
                        <ImageView
                            android:src="@drawable/burger"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"/>
                    </FrameLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="Burgers"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1E2A38"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Juicy &amp; grilled"
                            android:textSize="11sp"
                            android:textColor="#9CA3AF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Pizza Card -->
                <LinearLayout
                    android:id="@+id/cardPizza"
                    android:orientation="vertical"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:elevation="6dp"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="#FFF9F0">
                        <ImageView
                            android:src="@drawable/pizza"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"/>
                    </FrameLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="Pizza"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1E2A38"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Hot &amp; cheesy"
                            android:textSize="11sp"
                            android:textColor="#9CA3AF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Drinks Card -->
                <LinearLayout
                    android:id="@+id/cardDrinks"
                    android:orientation="vertical"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:elevation="6dp"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="#F0F8FF">
                        <ImageView
                            android:src="@drawable/drink"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"/>
                    </FrameLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="Drinks"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1E2A38"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Cold &amp; refreshing"
                            android:textSize="11sp"
                            android:textColor="#9CA3AF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Desserts Card -->
                <LinearLayout
                    android:id="@+id/cardDesserts"
                    android:orientation="vertical"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:elevation="6dp"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_columnWeight="1">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="#FFF0F8">
                        <ImageView
                            android:src="@drawable/dessert"
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"/>
                    </FrameLayout>

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="Desserts"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1E2A38"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Sweet treats"
                            android:textSize="11sp"
                            android:textColor="#9CA3AF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════ -->
    <!--  BOTTOM NAVIGATION BAR                     -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME (active) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="@drawable/nav_indicator"
                android:layout_marginBottom="4dp"/>
            <TextView android:text="🏠" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Home" android:textSize="10sp"
                android:textColor="#FF6B35" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- MENU -->
        <LinearLayout
            android:id="@+id/navRestaurant"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🍽️" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Menu" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CART -->
        <LinearLayout
            android:id="@+id/navCart"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="🛒" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Cart" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView android:text="👤" android:textSize="20sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Profile" android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>