<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:orientation="vertical"
        android:background="#FF6B35"
        android:padding="20dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/title"
            android:text="FoodDash"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/subtitle"
            android:text="What are you craving today?"
            android:textSize="14sp"
            android:textColor="#FFE0D0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Today's Special banner -->
            <LinearLayout
                android:id="@+id/cardSpecial"
                android:orientation="horizontal"
                android:background="#FF6B35"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="TODAY'S SPECIAL"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#FFE0D0"
                        android:letterSpacing="0.12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Pepperoni Pizza"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Only $10.99 today"
                        android:textSize="13sp"
                        android:textColor="#FFE0D0"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Order now →"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#33FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:layout_marginTop="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <ImageView
                    android:src="@drawable/pizza"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>

            <!-- Section label -->
            <TextView
                android:text="Categories"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E2A38"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="What do you feel like eating?"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Category Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2">

                <!-- Burger -->
                <LinearLayout
                    android:id="@+id/cardBurger"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_margin="6dp"
                    android:padding="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:src="@drawable/burger"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"/>

                    <TextView
                        android:text="Burgers"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Juicy &amp; grilled"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Pizza -->
                <LinearLayout
                    android:id="@+id/cardPizza"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_margin="6dp"
                    android:padding="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:src="@drawable/pizza"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"/>

                    <TextView
                        android:text="Pizza"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Hot &amp; cheesy"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Drinks -->
                <LinearLayout
                    android:id="@+id/cardDrinks"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_margin="6dp"
                    android:padding="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:src="@drawable/drink"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"/>

                    <TextView
                        android:text="Drinks"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Cold &amp; refreshing"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Desserts -->
                <LinearLayout
                    android:id="@+id/cardDesserts"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_margin="6dp"
                    android:padding="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:src="@drawable/dessert"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"/>

                    <TextView
                        android:text="Desserts"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Sweet treats"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/navHome" android:orientation="vertical"
            android:gravity="center" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent">
            <TextView android:text="🏠" android:textSize="18sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Home" android:textSize="10sp"
                android:textColor="#FF6B35" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navRestaurant" android:orientation="vertical"
            android:gravity="center" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent">
            <TextView android:text="🍽️" android:textSize="18sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Menu" android:textSize="10sp" android:textColor="#AAAAAA"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navCart" android:orientation="vertical"
            android:gravity="center" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent">
            <TextView android:text="🛒" android:textSize="18sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Cart" android:textSize="10sp" android:textColor="#AAAAAA"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:orientation="vertical"
            android:gravity="center" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="match_parent">
            <TextView android:text="👤" android:textSize="18sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Profile" android:textSize="10sp" android:textColor="#AAAAAA"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>